# Copy to .env and fill in strong random values, then `docker compose up -d`.
# Generate secrets with:  python -c "import secrets; print(secrets.token_urlsafe(32))"

PAIOS_RELAY_SECRET=replace-with-a-long-random-string
PAIOS_RELAY_ACCOUNT_KEY=replace-with-another-long-random-string
PAIOS_RELAY_ACCOUNT=default
PAIOS_RELAY_PORT=8770

# Optional direct TLS (otherwise terminate TLS at a reverse proxy):
# PAIOS_RELAY_TLS_CERT=/certs/fullchain.pem
# PAIOS_RELAY_TLS_KEY=/certs/privkey.pem
